# =============================================================================
# IDBI Innovate Backend — Environment Variables Example
# Copy this file to .env and fill in your actual values.
# =============================================================================

# ---------------------------------------------------------------------------
# DATABASE
# ---------------------------------------------------------------------------
# PostgreSQL connection string.
# Format: postgresql+psycopg2://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/idbi_innovate

# ---------------------------------------------------------------------------
# JWT / SECURITY
# ---------------------------------------------------------------------------
# A long, random secret key used to sign JWT tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-me-in-production

# Algorithm used for JWT signing (HS256 is standard)
ALGORITHM=HS256

# Token expiry in minutes (default 60 minutes = 1 hour)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Refresh token expiry in days (default 7 days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# POWER BI INTEGRATION (Azure AD App Registration)
# ---------------------------------------------------------------------------
# Azure AD Application (client) ID for the Power BI service principal
POWERBI_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Azure AD client secret value (not the secret ID)
POWERBI_CLIENT_SECRET=your-powerbi-client-secret

# Azure AD Tenant (Directory) ID
POWERBI_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Power BI Workspace (Group) ID where your reports live
POWERBI_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Power BI Report ID to embed
POWERBI_REPORT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Power BI Dataset ID (used for push/streaming datasets)
POWERBI_DATASET_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed frontend origins.
# Example: http://localhost:3000,https://idbi-innovate.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# ---------------------------------------------------------------------------
# APPLICATION
# ---------------------------------------------------------------------------
# Application environment: development | staging | production
APP_ENV=development

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Application host and port (used by uvicorn)
APP_HOST=0.0.0.0
APP_PORT=8000
